<Window x:Class="Shaballa.Win_DangNhap"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shaballa" 
        d:DataContext="{d:DesignInstance Type=local:ViewModel_Win_DangNhap}"
        mc:Ignorable="d"
        Title="Đăng nhập" 
        WindowStartupLocation="CenterScreen"  
        ResizeMode="NoResize"
        Height="600" 
        Width="900"
        MinWidth="335"
        MinHeight="475">
    <Window.Resources>
        <Style TargetType="local:WatermarkTextBox" BasedOn="{StaticResource WatermarkTextBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="2"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="1" IsHitTestVisible="False">
                                <Border Background="{TemplateBinding Foreground}"/>
                                <Border x:Name="B1" Background="#638f48" RenderTransformOrigin=".5,.5">
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleX="0"/>
                                    </Border.RenderTransform>
                                </Border>
                            </Grid>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0,8" IsHitTestVisible="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="B1" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0" ScaleY="2"/>
                                    </Setter.Value>
                                </Setter>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="B1" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="B1" Storyboard.TargetProperty="RenderTransform.ScaleX" To="0" Duration="0:0:.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Window.Background>
        <ImageBrush ImageSource="pack://application:,,,/Assets/ShaballaImage.png" Stretch="UniformToFill"/>
    </Window.Background>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>      
            <ColumnDefinition Width="310"/>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="400"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid Grid.Column="1" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid Height="100">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button Width="100" Style="{StaticResource Logo}"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel.Resources>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource TextBlock}">
                            <Setter Property="FontFamily" Value="Palatino Linotype"/>  
                            <Setter Property="Foreground" Value="#81b64c"/>
                            <Setter Property="FontStyle" Value="Italic"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="15"/>
                        </Style>
                    </StackPanel.Resources>
                    <TextBlock FontSize="30" Text="Shaballa"/>
                    <TextBlock Text="Coffee - tea" Grid.Row="1"/>
                </StackPanel> 
            </Grid>
            <Grid Grid.Row="1" Margin="0,10,0,0"> 
                <Border Style="{StaticResource BorderShadown}"/>
                <Viewbox>
                    <Grid>
                        <Calendar/>
                    </Grid>
                </Viewbox>
            </Grid>
        </Grid>
        <Grid Grid.Column="3" Grid.Row="1">
            <Border Style="{StaticResource BorderShadown}"/>
            <local:CornerRadiusGrid CornerRadius="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid>
                    <Border Background="#638f48"/>
                    <TextBlock Text="ĐĂNG NHẬP" Style="{StaticResource TextBlock}" Foreground="White" FontSize="17" FontWeight="Heavy"/>
                 </Grid>
                <Grid Grid.Row="1" Margin="30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38.78"/>
                        <RowDefinition/>
                        <RowDefinition Height="38.78"/>
                        <RowDefinition/>
                        <RowDefinition Height="38.78"/>
                        <RowDefinition/>
                        <RowDefinition Height="20"/>
                        <RowDefinition/>
                        <RowDefinition Height="50"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <local:DoubleComboBox ItemsSource="{Binding AccountTypes}" SelectedValue="{Binding SelectedAccountType}"/>
                    <local:WatermarkTextBox Text="{Binding TenDangNhap}" Watermark="Tài khoản" Grid.Row="2"/>
                    <local:WatermarkTextBox Text="{Binding MatKhau}" Watermark="Mật khẩu" Grid.Row="4"/>
                    <Button Grid.Row="6" Content="Quên mật khẩu?">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource Button}">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="#638f48"/>  
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="Red"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Style="{StaticResource HighLightButton}" Command="{Binding CmdDangNhap}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" Content="Đăng nhập" Grid.Row="8" FontSize="18"/>
                </Grid> 
            </local:CornerRadiusGrid>
        </Grid>
    </Grid>
</Window>
