<Window x:Class="Shaballa.Win_SuaThongTinNoiThat"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shaballa" d:DataContext="{d:DesignInstance Type=local:ViewModel_Win_SuaThongTinNoiThat}"
        mc:Ignorable="d"
        Title="Win_SuaThongTinNoiThat"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" 
        Height="600" 
        Width="500">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Margin="20,5">
            <TextBlock Text="Sửa thông tin bàn" Style="{StaticResource TextBlock}" HorizontalAlignment="Left" FontWeight="Heavy" FontSize="17" Margin="5"/>
            <Border Style="{StaticResource Layout}" Margin="5,10">
                <StackPanel Orientation="Horizontal" Margin="10">
                    <local:AutoCenterCanvas Width="70" AutoHorizontal="True" AutoVertical="True" IsHitTestVisible="False">
                        <ContentControl Content="{Binding BanGhe}"/>
                    </local:AutoCenterCanvas>
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="22"/>
                            <RowDefinition Height="40"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Trạng thái hiện tại" Style="{StaticResource TieuDeGray}" Margin="5,0"/>
                        <StackPanel Orientation="Horizontal" Grid.Row="1">
                            <StackPanel.Resources>
                                <Style x:Key="RadioButton" TargetType="RadioButton">
                                    <Setter Property="Foreground" Value="#1f2937"/>
                                    <Setter Property="Background" Value="#f0f0f0"/>
                                    <Setter Property="FontWeight" Value="Medium"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Margin" Value="5"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#e5e7eb"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Resources>
                            <RadioButton Content="Còn trống" Command="{Binding CmdChangeTrangThai}" CommandParameter="{x:Static local:TrangThai.Trong}" IsChecked="{Binding DiemPhucVu.TrangThai, Converter={local:Converter_TrangThaiSangBool}, ConverterParameter=0}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton" BasedOn="{StaticResource RadioButton}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="RadioButton">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                        <StackPanel Margin="2" Orientation="Horizontal">
                                                            <Path Margin="0,0,7,0" Data="M2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12ZM15.7071 9.29289C16.0976 9.68342 16.0976 10.3166 15.7071 10.7071L12.0243 14.3899C11.4586 14.9556 10.5414 14.9556 9.97568 14.3899L8.29289 12.7071C7.90237 12.3166 7.90237 11.6834 8.29289 11.2929C8.68342 10.9024 9.31658 10.9024 9.70711 11.2929L11 12.5858L14.2929 9.29289C14.6834 8.90237 15.3166 8.90237 15.7071 9.29289Z" Fill="{TemplateBinding Foreground}">
                                                                <Path.RenderTransform>
                                                                    <TransformGroup>
                                                                        <ScaleTransform ScaleX=".9" ScaleY=".9"/>
                                                                        <TranslateTransform X="2" Y="1"/>
                                                                    </TransformGroup>
                                                                </Path.RenderTransform>
                                                            </Path>
                                                            <ContentPresenter Margin="0,2,10,4" VerticalAlignment="Center" Grid.Column="1"/>
                                                        </StackPanel>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Background" Value="#22c55e"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <RadioButton Content="Đã đầy" Command="{Binding CmdChangeTrangThai}" CommandParameter="{x:Static local:TrangThai.DaDay}" IsChecked="{Binding DiemPhucVu.TrangThai, Converter={local:Converter_TrangThaiSangBool}, ConverterParameter=1}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton" BasedOn="{StaticResource RadioButton}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="RadioButton">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                        <StackPanel Margin="2" Orientation="Horizontal">
                                                            <Path Margin="0,0,7,0" Data="M12,2A10,10,0,1,0,22,12,10,10,0,0,0,12,2Zm4.24,11H7.76a1,1,0,1,1,0-2h8.48a1,1,0,0,1,0,2Z" Fill="{TemplateBinding Foreground}">
                                                                <Path.RenderTransform>
                                                                    <TransformGroup>
                                                                        <ScaleTransform ScaleX=".85" ScaleY=".85"/>
                                                                        <TranslateTransform X="2" Y=".5"/>
                                                                    </TransformGroup>
                                                                </Path.RenderTransform>
                                                            </Path>
                                                            <ContentPresenter Margin="0,2,10,4" VerticalAlignment="Center" Grid.Column="1"/>
                                                        </StackPanel>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#e5e7eb"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Background" Value="#ef4444"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                            <RadioButton Content="Bảo trì" Command="{Binding CmdChangeTrangThai}" CommandParameter="{x:Static local:TrangThai.BaoTri}" IsChecked="{Binding DiemPhucVu.TrangThai, Converter={local:Converter_TrangThaiSangBool}, ConverterParameter=2}">
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton" BasedOn="{StaticResource RadioButton}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="RadioButton">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                        <StackPanel Margin="2" Orientation="Horizontal">
                                                            <Path Margin="0,0,12,0" Data="M128,7.10542736e-15 C198.692448,7.10542736e-15 256,57.307552 256,128 C256,140.931179 254.082471,153.414494 250.516246,165.181113 L384,298.666667 C407.564149,322.230816 407.564149,360.435851 384,384 C360.435851,407.564149 322.230816,407.564149 298.666667,384 L165.181113,250.516246 C153.414494,254.082471 140.931179,256 128,256 C57.307552,256 7.10542736e-15,198.692448 7.10542736e-15,128 C7.10542736e-15,114.357909 2.13416363,101.214278 6.08683609,88.884763 L66.6347809,149.333333 L126.649,129.346 L129.329,126.666 L149.333333,66.7080586 L88.7145729,6.14152881 C101.0933,2.15385405 114.29512,7.10542736e-15 128,7.10542736e-15 Z" Fill="{TemplateBinding Foreground}">
                                                                <Path.LayoutTransform>
                                                                    <ScaleTransform ScaleX=".04" ScaleY=".04"/>
                                                                </Path.LayoutTransform>
                                                                <Path.RenderTransform>
                                                                    <TranslateTransform X="5" Y="5"/>
                                                                </Path.RenderTransform>
                                                            </Path>
                                                            <ContentPresenter Margin="0,2,10,4" VerticalAlignment="Center" Grid.Column="1"/>
                                                        </StackPanel>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#e5e7eb"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Background" Value="#6b7280"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
            <StackPanel Margin="5">
                <TextBlock Text="Tên bàn" Style="{StaticResource TieuDeGray}"/>
                <local:WatermarkTextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Watermark="Nhập tên bàn mới" Style="{StaticResource WatermarkTextBox}" Margin="0,5"/>
            </StackPanel>
            <UniformGrid Columns="2">
                <StackPanel Margin="5">
                    <TextBlock Text="vị trí X" Style="{StaticResource TieuDeGray}"/>
                    <local:WatermarkTextBox Text="{Binding X, UpdateSourceTrigger=PropertyChanged}" Watermark="Nhập tọa độ X" Style="{StaticResource WatermarkTextBox}" Margin="0,5"/>
                </StackPanel>  
                <StackPanel Margin="5">
                    <TextBlock Text="Vị trí Y" Style="{StaticResource TieuDeGray}"/>
                    <local:WatermarkTextBox Text="{Binding Y, UpdateSourceTrigger=PropertyChanged}" Watermark="Nhập tọa độ Y" Style="{StaticResource WatermarkTextBox}" Margin="0,5"/>
                </StackPanel>
            </UniformGrid>
            <Border Style="{StaticResource CornerRadiusBorder}" BorderBrush="WhiteSmoke" Padding="10" Margin="5">
                <StackPanel>
                    <TextBlock Text="Thông tin sau thay đổi" Style="{StaticResource TieuDe}" Margin="2"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" Height="56" Grid.Row="1" Margin="2">
                        <TextBlock Text="{Binding ThongTin}" VerticalAlignment="Top" Style="{StaticResource TieuDeGray}" FontSize="13"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Row="5" Margin="20,0">
            <Button Content="Hủy" Command="{Binding CmdColse}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource CornerRadiusButton}" Padding="16,8" FontWeight="Heavy" Margin="5"/>
            <Button Content="Xác nhận" IsEnabled="{Binding IsCanLuu}" Command="{Binding CmdLuu}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource HighLightButton}" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
