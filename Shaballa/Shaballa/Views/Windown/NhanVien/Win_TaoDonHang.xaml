<Window x:Class="Shaballa.Win_TaoDonHang"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shaballa" d:DataContext="{d:DesignInstance Type=local:ViewModel_Win_TaoDonHang}"
        mc:Ignorable="d"
        Title="Win_TaoDonHang"    
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" 
        Height="650" 
        Width="600">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Margin="20,5">
            <TextBlock Text="Thêm đơn hàng mới" Margin="5" Style="{StaticResource TextBlock}" HorizontalAlignment="Left" FontWeight="Heavy" FontSize="17"/>
            <StackPanel Margin="5">
                <TextBlock Text="Chọn mặt hàng" Style="{StaticResource TieuDeGray}"/>
                <Border Margin="0,5" Style="{StaticResource Layout}">
                    <local:CornerRadiusGrid CornerRadius="6">
                        <ScrollViewer Height="130" Padding="4" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding MatHangs}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.CmdTaoChiTiet, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource Button}">
                                                    <Setter Property="Background" Value="#d0ffffff"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Grid Margin="4">
                                                                    <Border Background="{TemplateBinding Background}" Style="{StaticResource CornerRadiusBorderMouseOver}" CornerRadius="6" Height="50"/>
                                                                    <ContentControl Content="{Binding}" Margin="2"/>
                                                                </Grid>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#ffffff"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </local:CornerRadiusGrid>
                </Border>
            </StackPanel>
            <StackPanel Margin="5">
                <TextBlock Text="Danh sách chi tiết" Style="{StaticResource TieuDeGray}"/>
                <Border Margin="0,5" Style="{StaticResource Layout}">
                    <local:CornerRadiusGrid CornerRadius="6">
                        <ScrollViewer Height="120" VerticalScrollBarVisibility="Visible" Padding="4">
                            <ItemsControl ItemsSource="{Binding ChiTiets}">
                                <ItemsControl.Resources>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="ItemTemplate" Value="{StaticResource ChiTietDonHangBan}"/>
                                    </Style>
                                </ItemsControl.Resources>
                                <!--<ItemContainerTemplate>
                                </ItemContainerTemplate>-->
                            </ItemsControl>
                        </ScrollViewer>
                    </local:CornerRadiusGrid>
                </Border>
            </StackPanel>
            <Border Style="{StaticResource CornerRadiusBorder}" BorderBrush="WhiteSmoke" Padding="10" Margin="5">
                <StackPanel>
                    <TextBlock Text="Ghi chú" Style="{StaticResource TieuDe}" Margin="2"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" Height="56" Margin="2">
                        <local:WatermarkTextBox Text="{Binding Note}" Watermark="Nhập ghi chú..." Style="{StaticResource TransparentTextBox}" VerticalAlignment="Top"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
        <Grid Margin="20,0" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions> 
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8">
                <TextBlock Text="Tổng đơn: " Style="{StaticResource TieuDeGray}"/>
                <TextBlock Text="{Binding ChiTiets.TongTien, StringFormat={}{0:N0} ₫}" FontSize="15" Grid.Column="1" Foreground="#3b82f6" FontWeight="Heavy"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="5">
                <Button Content="Hủy" Command="{Binding CmdHuy}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource CornerRadiusButton}" Padding="16,8" FontWeight="Heavy" Margin="5"/>
                <Button Content="Xác nhận" Command="{Binding CmdLuu}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource HighLightButton}" Margin="5"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
