<Window x:Class="Shaballa.Win_ChiTietDiemPhucVu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shaballa" 
        d:DataContext="{d:DesignInstance Type=local:ViewModel_Win_ChiTietDiemPhucVu}"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="{Binding DiemPhucVu.Name}"
        ResizeMode="NoResize"
        Height="700"
        Width="800">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Border Style="{StaticResource Layout}">
            <StackPanel Orientation="Horizontal" Margin="10">
                <local:AutoCenterCanvas Width="70" AutoHorizontal="True" AutoVertical="True" IsHitTestVisible="False">
                    <ContentControl Content="{Binding DiemPhucVu}"/>
                </local:AutoCenterCanvas>
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Trạng thái hiện tại" Style="{StaticResource TieuDeGray}" Margin="5,0"/>
                    <StackPanel Orientation="Horizontal" Grid.Row="1">
                        <StackPanel.Resources>
                            <Style x:Key="RadioButton" TargetType="RadioButton">
                                <Setter Property="Foreground" Value="#1f2937"/>
                                <Setter Property="Background" Value="#f0f0f0"/>
                                <Setter Property="FontWeight" Value="Medium"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Margin" Value="5"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#e5e7eb"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Resources>
                        <RadioButton Content="Còn trống" Command="{Binding CmdChangeTrangThai}" CommandParameter="{x:Static local:TrangThai.Trong}" IsChecked="{Binding DiemPhucVu.TrangThai, Converter={local:Converter_TrangThaiSangBool}, ConverterParameter=0}">
                            <RadioButton.Style>
                                <Style TargetType="RadioButton" BasedOn="{StaticResource RadioButton}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="RadioButton">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                    <StackPanel Margin="2" Orientation="Horizontal">
                                                        <Path Margin="0,0,7,0" Data="M2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12ZM15.7071 9.29289C16.0976 9.68342 16.0976 10.3166 15.7071 10.7071L12.0243 14.3899C11.4586 14.9556 10.5414 14.9556 9.97568 14.3899L8.29289 12.7071C7.90237 12.3166 7.90237 11.6834 8.29289 11.2929C8.68342 10.9024 9.31658 10.9024 9.70711 11.2929L11 12.5858L14.2929 9.29289C14.6834 8.90237 15.3166 8.90237 15.7071 9.29289Z" Fill="{TemplateBinding Foreground}">
                                                            <Path.RenderTransform>
                                                                <TransformGroup>
                                                                    <ScaleTransform ScaleX=".9" ScaleY=".9"/>
                                                                    <TranslateTransform X="2" Y="1"/>
                                                                </TransformGroup>
                                                            </Path.RenderTransform>
                                                        </Path>
                                                        <ContentPresenter Margin="0,2,10,4" VerticalAlignment="Center" Grid.Column="1"/>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Background" Value="#22c55e"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </RadioButton.Style>
                        </RadioButton>
                        <RadioButton Content="Đã đầy" Command="{Binding CmdChangeTrangThai}" CommandParameter="{x:Static local:TrangThai.DaDay}" IsChecked="{Binding DiemPhucVu.TrangThai, Converter={local:Converter_TrangThaiSangBool}, ConverterParameter=1}">
                            <RadioButton.Style>
                                <Style TargetType="RadioButton" BasedOn="{StaticResource RadioButton}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="RadioButton">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                    <StackPanel Margin="2" Orientation="Horizontal">
                                                        <Path Margin="0,0,7,0" Data="M12,2A10,10,0,1,0,22,12,10,10,0,0,0,12,2Zm4.24,11H7.76a1,1,0,1,1,0-2h8.48a1,1,0,0,1,0,2Z" Fill="{TemplateBinding Foreground}">
                                                            <Path.RenderTransform>
                                                                <TransformGroup>
                                                                    <ScaleTransform ScaleX=".85" ScaleY=".85"/>
                                                                    <TranslateTransform X="2" Y=".5"/>
                                                                </TransformGroup>
                                                            </Path.RenderTransform>
                                                        </Path>
                                                        <ContentPresenter Margin="0,2,10,4" VerticalAlignment="Center" Grid.Column="1"/>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#e5e7eb"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Background" Value="#ef4444"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </RadioButton.Style>
                        </RadioButton>
                        <RadioButton Content="Bảo trì" Command="{Binding CmdChangeTrangThai}" CommandParameter="{x:Static local:TrangThai.BaoTri}" IsChecked="{Binding DiemPhucVu.TrangThai, Converter={local:Converter_TrangThaiSangBool}, ConverterParameter=2}">
                            <RadioButton.Style>
                                <Style TargetType="RadioButton" BasedOn="{StaticResource RadioButton}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="RadioButton">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                    <StackPanel Margin="2" Orientation="Horizontal">
                                                        <Path Margin="0,0,12,0" Data="M128,7.10542736e-15 C198.692448,7.10542736e-15 256,57.307552 256,128 C256,140.931179 254.082471,153.414494 250.516246,165.181113 L384,298.666667 C407.564149,322.230816 407.564149,360.435851 384,384 C360.435851,407.564149 322.230816,407.564149 298.666667,384 L165.181113,250.516246 C153.414494,254.082471 140.931179,256 128,256 C57.307552,256 7.10542736e-15,198.692448 7.10542736e-15,128 C7.10542736e-15,114.357909 2.13416363,101.214278 6.08683609,88.884763 L66.6347809,149.333333 L126.649,129.346 L129.329,126.666 L149.333333,66.7080586 L88.7145729,6.14152881 C101.0933,2.15385405 114.29512,7.10542736e-15 128,7.10542736e-15 Z" Fill="{TemplateBinding Foreground}">
                                                            <Path.LayoutTransform>
                                                                <ScaleTransform ScaleX=".04" ScaleY=".04"/>
                                                            </Path.LayoutTransform>
                                                            <Path.RenderTransform>
                                                                <TranslateTransform X="5" Y="5"/>
                                                            </Path.RenderTransform>
                                                        </Path>
                                                        <ContentPresenter Margin="0,2,10,4" VerticalAlignment="Center" Grid.Column="1"/>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#e5e7eb"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Background" Value="#6b7280"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </RadioButton.Style>
                        </RadioButton>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
        <Border Style="{StaticResource Layout}" Padding="10" Grid.Row="1">
            <ContentControl>
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="350"/>   
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <local:WatermarkTextBox Watermark="Tìm kiếm đơn hàng..." Margin="8" Style="{StaticResource SearchTextBox}"/>
                                            <Button Command="{Binding CmdTaoDonHang}" Content="+ Tạo đơn hàng" Style="{StaticResource HighLightButton}" Margin="8" Padding="10,0" Grid.Column="2"/>
                                            <ToggleButton x:Name="T1" Content="Bộ lọc" Grid.Column="3">
                                                <ToggleButton.Style>
                                                    <Style TargetType="ToggleButton">
                                                        <Setter Property="Background" Value="#e2f0cd"/>
                                                        <Setter Property="Foreground" Value="#638f48"/>
                                                        <Setter Property="FontWeight" Value="Medium"/>
                                                        <Setter Property="Cursor" Value="Hand"/>
                                                        <Setter Property="FontSize" Value="15"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border Background="{TemplateBinding Background}" Style="{StaticResource Layout}" CornerRadius="5" Padding="10">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Canvas Width="25" Height="17">
                                                                                <Path Fill="{TemplateBinding Foreground}" Data="M41.8,8H21.7A6.2,6.2,0,0,0,16,4a6,6,0,0,0-5.6,4H6.2A2.1,2.1,0,0,0,4,10a2.1,2.1,0,0,0,2.2,2h4.2A6,6,0,0,0,16,16a6.2,6.2,0,0,0,5.7-4H41.8A2.1,2.1,0,0,0,44,10,2.1,2.1,0,0,0,41.8,8ZM16,12a2,2,0,1,1,2-2A2,2,0,0,1,16,12Z"/>
                                                                                <Path Fill="{TemplateBinding Foreground}" Data="M41.8,22H37.7A6.2,6.2,0,0,0,32,18a6,6,0,0,0-5.6,4H6.2a2,2,0,1,0,0,4H26.4A6,6,0,0,0,32,30a6.2,6.2,0,0,0,5.7-4h4.1a2,2,0,1,0,0-4ZM32,26a2,2,0,1,1,2-2A2,2,0,0,1,32,26Z" />
                                                                                <Path Fill="{TemplateBinding Foreground}" Data="M41.8,36H24.7A6.2,6.2,0,0,0,19,32a6,6,0,0,0-5.6,4H6.2a2,2,0,1,0,0,4h7.2A6,6,0,0,0,19,44a6.2,6.2,0,0,0,5.7-4H41.8a2,2,0,1,0,0-4ZM19,40a2,2,0,1,1,2-2A2,2,0,0,1,19,40Z"/>
                                                                                <Canvas.RenderTransform>
                                                                                    <TransformGroup>
                                                                                        <ScaleTransform ScaleX=".4" ScaleY=".4"/>
                                                                                    </TransformGroup>
                                                                                </Canvas.RenderTransform>
                                                                            </Canvas>
                                                                            <ContentPresenter IsHitTestVisible="False"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#e7f5d2"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ToggleButton.Style>
                                            </ToggleButton>
                                        </Grid>
                                        <Grid x:Name="G1" Visibility="Collapsed" Margin="8" Grid.Row="1">
                                            <Grid.Resources>
                                                <Style TargetType="UniformGrid">
                                                    <Setter Property="Columns" Value="2"/>
                                                    <Setter Property="Rows" Value="1"/>
                                                </Style>
                                                <Style TargetType="local:NumericUpDown" BasedOn="{StaticResource NumericUpDown}">
                                                    <Setter Property="Scroll" Value="True"/>
                                                    <Setter Property="MinValue" Value="0"/>
                                                    <Setter Property="Margin" Value="5"/>
                                                </Style>
                                                <Style x:Key="Layout" TargetType="Border" BasedOn="{StaticResource Layout}">
                                                    <Setter Property="Padding" Value="10"/>
                                                </Style>
                                                <Style x:Key="TieuDeGray" TargetType="TextBlock" BasedOn="{StaticResource TieuDeGray}">
                                                    <Setter Property="Margin" Value="5"/>
                                                </Style>
                                            </Grid.Resources>
                                            <Border Style="{StaticResource BorderShadown}"/>
                                            <StackPanel Margin="7">
                                                <UniformGrid>
                                                    <Border Style="{StaticResource Layout}">
                                                        <StackPanel>
                                                            <TextBlock Text="Giá (VNĐ)" Style="{StaticResource TieuDeGray}"/>
                                                            <UniformGrid>
                                                                <local:NumericUpDown Watermark="Tối thiểu"/>
                                                                <local:NumericUpDown Watermark="Tối đa"/>
                                                            </UniformGrid>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Style="{StaticResource Layout}">
                                                        <StackPanel>
                                                            <TextBlock Text="Số lượng món" Style="{StaticResource TieuDeGray}"/>
                                                            <UniformGrid>
                                                                <local:NumericUpDown Watermark="Tối thiểu"/>
                                                                <local:NumericUpDown Watermark="Tối đa"/>
                                                            </UniformGrid>
                                                        </StackPanel>
                                                    </Border>
                                                </UniformGrid>
                                                <StackPanel Margin="4">
                                                    <TextBlock Text="Sắp xếp phụ" Style="{StaticResource TieuDeGray}"/>
                                                    <local:DoubleComboBox ItemsSource="{Binding TieuChiSapXep}" SelectedValue="{Binding SelectedTieuChi}" Margin="4"/>
                                                </StackPanel>
                                                <Button Style="{StaticResource CornerRadiusButton}" Content="Xóa bộ lọc" Margin="10" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, ElementName=T1}" Value="True">
                                            <Setter TargetName="G1" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Border>
        <local:CornerRadiusGrid Grid.Row="2" CornerRadius="10">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden" Grid.Row="1">
                <ItemsControl ItemsSource="{Binding DiemPhucVu.DonHangs}">
                    <ItemsControl.Resources>
                        <Style TargetType="ItemsControl">
                            <Setter Property="ItemTemplate" Value="{StaticResource DonHangBan}"/>
                        </Style>
                    </ItemsControl.Resources>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="local:DragDropBehavior.CanDrop" Value="True"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>
            </ScrollViewer>
        </local:CornerRadiusGrid>
    </Grid>
</Window>
