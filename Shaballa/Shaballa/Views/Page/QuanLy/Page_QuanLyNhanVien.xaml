<Page x:Class="Shaballa.Page_QuanLyNhanVien"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Shaballa" d:DataContext="{d:DesignInstance Type=local:ViewModel_Page_QuanLyNhanVien}"
      mc:Ignorable="d" 
      Height="700" d:Width="1000"
      Title="Page_QuanLyNhanVien">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Border Style="{StaticResource Layout}">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition MinWidth="200" MaxWidth="330" Width="2*"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <local:WatermarkTextBox Watermark="Tìm kiếm nhân viên..." Margin="8" Style="{StaticResource SearchTextBox}"/>
                    <Button Command="{Binding CmdThemNhanVien}" Content="+ Thêm nhân viên" Style="{StaticResource HighLightButton}" Margin="8" Padding="10,0" Grid.Column="2"/>
                </Grid>
            </Grid>
        </Border>
        <Border Style="{StaticResource CornerRadiusBorder}" Grid.Row="1" Margin="8">
            <local:CornerRadiusGrid CornerRadius="6">
                <ScrollViewer Padding="10" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Accounts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <local:ResponsiveUniformGrid ResponsiveColums="10000:4,900:3,700:2,500:1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.CmdEdit, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Style="{StaticResource TransparentButton}"> 
                                    <Border Style="{StaticResource BorderTranslate}" Margin="5">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="200"/>
                                            </Grid.RowDefinitions>
                                            <Border Background="#f0f0f0" Style="{StaticResource Header}">
                                                <TextBlock Margin="12,5" Text="{Binding ID}" Style="{StaticResource TieuDe}" Foreground="{Binding TrangThaiNguyenLieu, Converter={local:Converter_DataSangColorForeground}}"/>
                                            </Border>
                                            <Border Style="{StaticResource DanhMucItem}" BorderBrush="#f0f0f0" Background="#f5f5f5" Padding="4">
                                                <Grid Margin="4">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition/>
                                                    </Grid.RowDefinitions>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition/>
                                                        </Grid.ColumnDefinitions>
                                                        <local:CornerRadiusGrid Style="{StaticResource ImageLayout}" Height="60" Width="60">
                                                            <Image Source="{Binding Image, Converter={local:Converter_ArraySangBitmap}}" Style="{StaticResource ImageMouseOver}"/>
                                                        </local:CornerRadiusGrid>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2">
                                                            <StackPanel.Resources>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextBlock}">
                                                                    <Setter Property="Foreground" Value="{Binding TrangThaiNguyenLieu, Converter={local:Converter_DataSangColorForeground}}"/>
                                                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                                                    <Setter Property="FontWeight" Value="Medium"/>
                                                                    <Setter Property="FontSize" Value="13.5"/>
                                                                    <Setter Property="Margin" Value="2"/>
                                                                </Style>
                                                            </StackPanel.Resources>
                                                            <TextBlock Text="{Binding Name}" FontWeight="Heavy"/>
                                                            <TextBlock Text="{Binding Phone}"/>
                                                            <TextBlock Text="{Binding Address}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                    <Border Style="{StaticResource CornerRadiusBorder}" BorderBrush="WhiteSmoke" Padding="10" Margin="3" Grid.Row="1">
                                                        <StackPanel>
                                                            <TextBlock Text="Ghi chú" Style="{StaticResource TieuDe}" Margin="2"/>
                                                            <ScrollViewer HorizontalScrollBarVisibility="Disabled" MaxHeight="56" Grid.Row="1" Margin="2">
                                                                <local:WatermarkTextBox Text="{Binding Note}" Watermark="Nhập ghi chú..." Style="{StaticResource TransparentTextBox}"/>
                                                            </ScrollViewer>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </local:CornerRadiusGrid>
        </Border>
    </Grid>
</Page>
