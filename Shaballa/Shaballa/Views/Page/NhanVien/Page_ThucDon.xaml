                <local:ResponsiveRow ResponsiveSize="900" NewSize="0" Height="5*"/>
                <local:ResponsiveRow ResponsiveSize="900" NewSize="Auto" Height="0"/>
                <local:ResponsiveRow ResponsiveSize="900" NewSize="Auto" Height="0"/>
            </Grid.RowDefinitions>
            <Grid Margin="8" Grid.RowSpan="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Border Background="#638f48" Style="{StaticResource Header}">
