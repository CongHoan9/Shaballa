                                <ScaleTransform ScaleX=".35" ScaleY=".35"/>
                            </Path.LayoutTransform>
                        </Path>
                        <TextBlock Text="Danh mục topping" Style="{StaticResource TieuDe}"/>
                    </Grid>
                </Border>
                <Border Style="{StaticResource DanhMucItem}" BorderBrush="#3b82f6" Background="#5ba2ff">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding Toppings}" Style="{StaticResource DanhMuc}">

                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </local:CanJumpGrid>
        </Grid>
    </local:ResponsiveScrollViewer>
</Page>
