                            </Path.LayoutTransform>
                        </Path>
                        <TextBlock Text="Danh mục đồ ăn" Style="{StaticResource TieuDe}"/>
                    </Grid>
                </Border>
                <Border Style="{StaticResource DanhMucItem}" BorderBrush="#ef4444" Background="#ff6666">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding DoAns.Items}" Style="{StaticResource DanhMuc}"/>
                    </ScrollViewer>
                </Border>
            </local:CanJumpGrid>
            <local:CanJumpGrid ResponsiveSize="900" Grid.Column="1" Grid.Row="1" NewColumn="0" NewRow="3" Margin="8">
