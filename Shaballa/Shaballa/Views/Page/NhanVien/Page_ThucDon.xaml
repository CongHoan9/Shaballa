<Page x:Class="Shaballa.Page_ThucDon"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Shaballa" 
      d:DataContext="{d:DesignInstance Type=local:ViewModel_Page_ThucDon}"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1100"
      Title="Page_ThucDon">
    <Page.Resources>
        <Style x:Key="TieuDe" TargetType="TextBlock" BasedOn="{StaticResource TieuDe}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Grid.Column" Value="1"/>
            <Setter Property="Padding" Value="2,2,5,2"/>
        </Style>
        <Style TargetType="Path">
            <Setter Property="Fill" Value="White"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
        <Style x:Key="DanhMuc" TargetType="ItemsControl">
            <Setter Property="ItemTemplate" Value="{StaticResource Menu}"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <local:ResponsiveUniformGrid ResponsiveColums="1200:4,900:3,700:2,500:1"/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="VerticalAlignment" Value="Top"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollViewer">
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Hidden"/>
            <Setter Property="MaxHeight" Value="650"/>
            <Setter Property="Grid.Row" Value="1"/>
        </Style>
    </Page.Resources>
