                                                        <Path.RenderTransform>
                                                            <TransformGroup>
                                                                <ScaleTransform ScaleX=".7" ScaleY=".7"/>
                                                            </TransformGroup>
                                                        </Path.RenderTransform>
                                                    </Path>
                                                </StackPanel>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#81b64c"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Resources>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width=".5*" MinWidth="80"/>  
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition MinWidth="80"/> 
                                <local:ResponsiveColumn Width="2*" ResponsiveSize="600" NewSize="0"/>
                                <ColumnDefinition/>
                                <ColumnDefinition MinWidth="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Ảnh"/>
                            <Button Command="{Binding CmdSort}" CommandParameter="Name" Content="Nguyên liệu" Grid.Column="1"/>
                            <Button Command="{Binding CmdSort}" CommandParameter="Gia" Content="Giá" Grid.Column="2"/>
                            <TextBlock Text="Mô tả nguyên liệu" Grid.Column="3"/>
                            <Button Command="{Binding CmdSort}" CommandParameter="TonKho" Content="Tồn" Grid.Column="4"/>
                            <Button Command="{Binding CmdSort}" CommandParameter="TrangThaiNguyenLieu" HorizontalAlignment="Right" Content="Trạng thái" Grid.Column="5"/>
                        </Grid>
                        <Border Style="{StaticResource Line}" Margin="8,4"/>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled" MaxHeight="500" Padding="4">
                        <ItemsControl ItemsSource="{Binding NguyenLieus}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="ItemTemplate" Value="{StaticResource NguyenLieu}"/>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="local:DragDropBehavior.CanDrop" Value="True"/>
                                    <Setter Property="VerticalAlignment" Value="Top"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
            <local:CanJumpGrid ResponsiveSize="900" NewColumn="0" NewRow="1" Grid.Column="1" Grid.Row="0" Margin="8">
                <Border Style="{StaticResource BorderShadown}" CornerRadius="10"/>
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                </Grid>
            </local:CanJumpGrid>
        </Grid>
