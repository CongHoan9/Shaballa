                                                </TransformGroup>
                                            </Path.RenderTransform>
                                        </Path>
                                    </Grid>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource TieuDe}" Text="Tồn kho"/>
                                        <TextBlock Style="{StaticResource Thongtin}" Text="{Binding  I}"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                            <Grid Grid.Column="1">
                                <Border Background="#fee2e2"/>
                                <Grid VerticalAlignment="Center" Margin="20">
