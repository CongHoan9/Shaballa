                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Style="{StaticResource Grid}">
                                        <Ellipse Fill="#fcc6c6"/>
