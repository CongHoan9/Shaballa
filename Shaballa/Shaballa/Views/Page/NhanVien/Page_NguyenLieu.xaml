<Page x:Class="Shaballa.Page_NguyenLieu"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Shaballa" d:DataContext="{d:DesignInstance Type=local:ViewModel_Page_NguyenLieu}"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Page_NguyenLieu">
    <local:ResponsiveScrollViewer ResponsiveSize="900" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <Grid.ColumnDefinitions>
                <local:ResponsiveColumn Width="5*"/>
                <local:ResponsiveColumn ResponsiveSize="900" NewSize="0" Width="0"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <local:ResponsiveRow ResponsiveSize="900" NewSize="Auto" Height="*"/>
                <local:ResponsiveRow ResponsiveSize="900" NewSize="Auto" Height="0"/>
            </Grid.RowDefinitions>
            <Border Style="{StaticResource Layout}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <Grid>
                            <Grid.Resources>
                                <Style x:Key="TieuDe" TargetType="TextBlock" BasedOn="{StaticResource TieuDe}">
                                    <Setter Property="Foreground" Value="#606060"/>
                                    <Setter Property="FontWeight" Value="Medium"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Padding" Value="0"/>
                                </Style>
                                <Style x:Key="Thongtin" TargetType="TextBlock" BasedOn="{StaticResource Thongtin}">
                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                    <Setter Property="FontStyle" Value="Normal"/>
                                    <Setter Property="FontWeight" Value="Heavy"/>
                                    <Setter Property="FontSize" Value="20"/>
                                </Style>
                                <Style TargetType="Path">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                                <Style TargetType="Border" BasedOn="{StaticResource BorderShadown}">
                                    <Setter Property="CornerRadius" Value="6"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Padding" Value="10"/>
                                    <Setter Property="Margin" Value="8"/>
                                </Style>
                                <Style x:Key="Grid" TargetType="Grid">
                                    <Setter Property="Height" Value="40"/>
                                    <Setter Property="Width" Value="40"/>
