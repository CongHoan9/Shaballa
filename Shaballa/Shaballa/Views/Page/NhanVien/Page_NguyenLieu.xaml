                                                                                                <TransformGroup>
                                                                                                    <ScaleTransform ScaleX=".4" ScaleY=".4"/>
                                                                                                </TransformGroup>
                                                                                            </Canvas.RenderTransform>
                                                                                        </Canvas>
                                                                                        <ContentPresenter IsHitTestVisible="False"/>
                                                                                    </StackPanel>
                                                                                </Border>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="#e7f5d2"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ToggleButton.Style>
                                                        </ToggleButton>
                                                    </Grid>
