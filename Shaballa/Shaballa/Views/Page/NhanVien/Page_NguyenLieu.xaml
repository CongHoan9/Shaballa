                                                            <Style TargetType="UniformGrid">
                                                                <Setter Property="Columns" Value="2"/>
                                                                <Setter Property="Rows" Value="1"/>
                                                            </Style>
                                                            <Style TargetType="local:NumericUpDown" BasedOn="{StaticResource NumericUpDown}">
                                                                <Setter Property="Scroll" Value="True"/>
                                                                <Setter Property="MinValue" Value="0"/>
                                                                <Setter Property="Margin" Value="5"/>
                                                            </Style>
                                                            <Style x:Key="Layout" TargetType="Border" BasedOn="{StaticResource Layout}">
                                                                <Setter Property="Padding" Value="10"/>
                                                            </Style>
                                                            <Style x:Key="TieuDeGray" TargetType="TextBlock" BasedOn="{StaticResource TieuDeGray}">
                                                                <Setter Property="Margin" Value="5"/>
                                                            </Style>
                                                        </Grid.Resources>
                                                        <Border Style="{StaticResource BorderShadown}"/>
                                                        <StackPanel Margin="7">
                                                            <UniformGrid>
                                                                <Border Style="{StaticResource Layout}">
                                                                    <StackPanel>
                                                                        <TextBlock Text="Giá (VNĐ)" Style="{StaticResource TieuDeGray}"/>
                                                                        <UniformGrid>
                                                                            <local:NumericUpDown Watermark="Tối thiểu"/>
                                                                            <local:NumericUpDown Watermark="Tối đa"/>
                                                                        </UniformGrid>
                                                                    </StackPanel>
                                                                </Border>
                                                                <Border Style="{StaticResource Layout}">
                                                                    <StackPanel>
                                                                        <TextBlock Text="Tồn kho" Style="{StaticResource TieuDeGray}"/>
                                                                        <UniformGrid>
                                                                            <local:NumericUpDown Watermark="Tối thiểu"/>
                                                                            <local:NumericUpDown Watermark="Tối đa"/>
                                                                        </UniformGrid>
                                                                    </StackPanel>
                                                                </Border>
                                                            </UniformGrid>
                                                            <Button Style="{StaticResource CornerRadiusButton}" Content="Xóa bộ lọc" Margin="10" HorizontalAlignment="Right"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsChecked, ElementName=T1}" Value="True">
                                                        <Setter TargetName="G1" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ContentControl.Style>
                        </ContentControl>
                        <Grid Margin="12,0">
                            <Grid.Resources>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextBlock}">
                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                    <Setter Property="Foreground" Value="#606060"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Margin" Value="6"/>
                                </Style>
                                <Style TargetType="Button">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                    <Setter Property="Foreground" Value="#606060"/>
                                    <Setter Property="FontWeight" Value="Medium"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <StackPanel Background="Transparent" Orientation="Horizontal">
                                                    <ContentPresenter Margin="6"/>
